{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/data/:file", "destination": "/api/data/:file" },
    { "source": "/api/members/:id", "destination": "/api/members/:id" },
    { "source": "/api/clans/:id", "destination": "/api/clans/:id" },
    { "source": "/api/users/:id", "destination": "/api/users/:id" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}
